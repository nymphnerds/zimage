{
  "manifest_version": 1,
  "id": "zimage",
  "name": "Z-Image Turbo",
  "short_name": "ZI",
  "version": "0.1.4",
  "description": "Local Z-Image Turbo image generation backend using the pinned Nunchaku runtime.",
  "category": "image",
  "packaging": "repo",
  "repo": {
    "url": "https://github.com/nymphnerds/zimage.git",
    "branch": "main"
  },
  "source": {
    "type": "repo",
    "repo": "https://github.com/nymphnerds/zimage.git",
    "ref": "main"
  },
  "install": {
    "root": "$HOME/Z-Image",
    "entrypoint": "scripts/install_zimage.sh",
    "version_marker": "$HOME/Z-Image/.nymph-module-version",
    "installed_markers": [
      "$HOME/Z-Image/.nymph-module-version"
    ]
  },
  "runtime": {
    "host": "127.0.0.1",
    "port": 8090,
    "health_url": "http://127.0.0.1:8090/health",
    "server_info_url": "http://127.0.0.1:8090/server_info"
  },
  "artifacts": {
    "models_root": "$HOME/NymphsData/models",
    "cache_root": "$HOME/NymphsData/cache",
    "outputs_root": "$HOME/NymphsData/outputs/zimage",
    "logs_root": "$HOME/NymphsData/logs/zimage",
    "legacy_outputs_root": "$HOME/Z-Image/outputs",
    "legacy_logs_root": "$HOME/Z-Image/logs",
    "huggingface_cache": "$HOME/NymphsData/cache/huggingface"
  },
  "entrypoints": {
    "install": "scripts/install_zimage.sh",
    "status": "scripts/zimage_status.sh",
    "start": "scripts/zimage_start.sh",
    "stop": "scripts/zimage_stop.sh",
    "open": "scripts/zimage_open.sh",
    "logs": "scripts/zimage_logs.sh",
    "fetch_models": "scripts/zimage_fetch_models.sh",
    "smoke_test": "scripts/zimage_smoke_test.sh",
    "uninstall": "scripts/zimage_uninstall.sh"
  },
  "ui": {
    "page": "custom",
    "page_kind": "zimage",
    "sort_order": 20,
    "standard_lifecycle_rail": true,
    "manager_ui": {
      "type": "local_html",
      "entrypoint": "ui/manager.html",
      "title": "Fetch Models"
    }
  },
  "uninstall": {
    "supports_purge": true,
    "requires_confirmation": true,
    "dry_run_arg": "--dry-run",
    "confirm_arg": "--yes",
    "purge_arg": "--purge",
    "preserve_by_default": [
      "outputs",
      "logs",
      "Hugging Face cache"
    ],
    "removes_by_default": [
      "runtime source files",
      ".venv-nunchaku",
      "generated module scripts"
    ]
  },
  "dependencies": {
    "python": "3.11",
    "cuda": "13.0 toolkit with nvcc",
    "torch": "2.11.0+cu130",
    "diffusers": "0.37.1",
    "nunchaku": {
      "repo": "https://github.com/nymphnerds/nunchaku.git",
      "commit": "a2a4f2444a092974ba53323ba0681a523ff98031"
    },
    "model": "Tongyi-MAI/Z-Image-Turbo",
    "nunchaku_weights": "nunchaku-ai/nunchaku-z-image-turbo",
    "supported_nunchaku_weights": [
      {
        "precision": "int4",
        "rank": 32,
        "file": "svdq-int4_r32-z-image-turbo.safetensors",
        "label": "INT4 r32 - fast / lower VRAM"
      },
      {
        "precision": "int4",
        "rank": 128,
        "file": "svdq-int4_r128-z-image-turbo.safetensors",
        "label": "INT4 r128 - balanced"
      },
      {
        "precision": "int4",
        "rank": 256,
        "file": "svdq-int4_r256-z-image-turbo.safetensors",
        "label": "INT4 r256 - highest rank"
      },
      {
        "precision": "fp4",
        "rank": 32,
        "file": "svdq-fp4_r32-z-image-turbo.safetensors",
        "label": "FP4 r32 - experimental compare"
      },
      {
        "precision": "fp4",
        "rank": 128,
        "file": "svdq-fp4_r128-z-image-turbo.safetensors",
        "label": "FP4 r128 - experimental compare"
      }
    ],
    "supported_precisions": [
      "auto",
      "int4",
      "fp4"
    ],
    "default_precision": "auto",
    "default_rank": 32
  },
  "notes": [
    "This module replaces the old Nymphs2D2 manager install target.",
    "The backend still accepts NYMPHS2D2 compatibility environment variables during migration.",
    "Do not vendor the Nunchaku clone or model weights into this repo."
  ]
}
