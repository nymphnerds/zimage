{
  "manifest_version": 1,
  "id": "zimage",
  "name": "Nymphs Image",
  "short_name": "NI",
  "version": "0.1.76",
  "description": "Nymphs Image frontend for local Z-Image Turbo, Gemini Flash image generation, and part extraction.",
  "category": "image",
  "kind": "image",
  "packaging": "repo",
  "repo": {
    "url": "https://github.com/nymphnerds/zimage.git",
    "branch": "main"
  },
  "source": {
    "type": "repo",
    "repo": "https://github.com/nymphnerds/zimage.git",
    "ref": "main"
  },
  "install": {
    "root": "$HOME/Z-Image",
    "entrypoint": "scripts/install_zimage.sh",
    "version_marker": "$HOME/Z-Image/.nymph-module-version",
    "installed_markers": [
      "$HOME/Z-Image/.nymph-module-version"
    ]
  },
  "runtime": {
    "host": "127.0.0.1",
    "port": 8090,
    "health_url": "http://127.0.0.1:8090/health",
    "server_info_url": "http://127.0.0.1:8090/server_info",
    "frontend_url": "http://127.0.0.1:8090/nymph"
  },
  "artifacts": {
    "models_root": "$HOME/NymphsData/models",
    "cache_root": "$HOME/NymphsData/cache",
    "outputs_root": "$HOME/NymphsData/outputs/zimage",
    "logs_root": "$HOME/NymphsData/logs/zimage",
    "legacy_outputs_root": "$HOME/Z-Image/outputs",
    "legacy_logs_root": "$HOME/Z-Image/logs",
    "huggingface_cache": "$HOME/NymphsData/cache/huggingface"
  },
  "entrypoints": {
    "install": "scripts/install_zimage.sh",
    "update": "scripts/zimage_update.sh",
    "status": "scripts/zimage_status.sh",
    "start": "scripts/zimage_start.sh",
    "restart": "scripts/zimage_restart.sh",
    "stop": "scripts/zimage_stop.sh",
    "open": "scripts/zimage_open.sh",
    "open_nymph_ui": "scripts/zimage_nymph_ui.sh",
    "open_config": "scripts/zimage_open_config.sh",
    "open_image_presets": "scripts/zimage_open_image_presets.sh",
    "open_image_settings_presets": "scripts/zimage_open_image_settings_presets.sh",
    "logs": "scripts/zimage_logs.sh",
    "delete_models": "scripts/zimage_delete_models.sh",
    "fetch_models": "scripts/zimage_fetch_models.sh",
    "smoke_test": "scripts/zimage_smoke_test.sh",
    "uninstall": "scripts/zimage_uninstall.sh",
    "open_lora": "scripts/zimage_open_lora.sh",
    "open_weights": "scripts/zimage_open_weights.sh",
    "open_outputs": "scripts/zimage_open_outputs.sh"
  },
  "ui": {
    "sort_order": 20,
    "standard_lifecycle_rail": true,
    "manager_ui": {
      "type": "local_url",
      "title": "Nymphs Image",
      "url": "http://127.0.0.1:8090/nymph",
      "requires_running": true,
      "start_action": "open_nymph_ui",
      "stop_action": "stop"
    },
    "manager_action_groups": [
      {
        "id": "model_fetch",
        "title": "Model Fetch",
        "layout": "compact",
        "entrypoint": "fetch_models",
        "result": "show_logs",
        "visibility": "installed",
        "description": "Install sets up the backend only. Fetch Models downloads the actual Z-Image model files.\nZ-Image Turbo is the fast local default for normal prompts.\nBrain owns local vision models such as Qwen Vision for LoRA captioning and parts planning.\nFor FLUX.1-dev or FLUX.1-Kontext-dev, use the separate FLUX fetch action because those model families require BFL terms review.",
        "links": [
          {
            "label": "Base model",
            "url": "https://huggingface.co/Tongyi-MAI/Z-Image-Turbo"
          },
          {
            "label": "Quantized weights",
            "url": "https://huggingface.co/nunchaku-ai/nunchaku-z-image-turbo"
          }
        ],
        "fields": [
          {
            "name": "quantized_weight",
            "type": "select",
            "label": "Download",
            "arg": "--model",
            "default": "svdq-int4_r32-z-image-turbo.safetensors",
            "options": [
              {
                "label": "All weights",
                "value": "all",
                "description": "Download every published compatible weight so Blender can switch presets later"
              },
              {
                "label": "int4_r32",
                "value": "svdq-int4_r32-z-image-turbo.safetensors",
                "description": "INT4 r32 - fastest, lowest VRAM"
              },
              {
                "label": "int4_r128",
                "value": "svdq-int4_r128-z-image-turbo.safetensors",
                "description": "INT4 r128 - recommended RTX 20/30/40"
              },
              {
                "label": "int4_r256",
                "value": "svdq-int4_r256-z-image-turbo.safetensors",
                "description": "INT4 r256 - highest quality, more VRAM"
              },
              {
                "label": "fp4_r32",
                "value": "svdq-fp4_r32-z-image-turbo.safetensors",
                "description": "FP4 r32 - fastest RTX 50 option"
              },
              {
                "label": "fp4_r128",
                "value": "svdq-fp4_r128-z-image-turbo.safetensors",
                "description": "FP4 r128 - recommended RTX 50"
              }
            ]
          },
          {
            "name": "hf_token",
            "type": "secret",
            "label": "Hugging Face token",
            "secret_id": "huggingface.token",
            "env": "NYMPHS3D_HF_TOKEN",
            "optional": true
          }
        ],
        "submit": {
          "label": "Fetch Models"
        }
      },
      {
        "id": "flux_model_fetch",
        "title": "FLUX Fetch",
        "layout": "compact",
        "entrypoint": "fetch_models",
        "result": "show_logs",
        "visibility": "installed",
        "description": "Fetch local FLUX model files only after reviewing the upstream BFL terms.\nFLUX.1-dev is local text-to-image.\nFLUX.1-Kontext-dev is local image editing and source-image part extraction.\nLocal parts planning requires Brain with a vision-capable model, such as Qwen Vision.\nNymphs Image only downloads the FLUX image side.",
        "links": [
          {
            "label": "FLUX.1-dev terms",
            "url": "https://huggingface.co/black-forest-labs/FLUX.1-dev"
          },
          {
            "label": "FLUX.1-Kontext-dev terms",
            "url": "https://huggingface.co/black-forest-labs/FLUX.1-Kontext-dev"
          },
          {
            "label": "Nunchaku FLUX.1-dev weights",
            "url": "https://huggingface.co/nunchaku-tech/nunchaku-flux.1-dev"
          },
          {
            "label": "Nunchaku FLUX.1-Kontext-dev weights",
            "url": "https://huggingface.co/nunchaku-tech/nunchaku-flux.1-kontext-dev"
          }
        ],
        "fields": [
          {
            "name": "flux_download",
            "type": "select",
            "label": "Download",
            "arg": "--model",
            "default": "local_parts_flux_16gb",
            "options": [
              {
                "label": "Local Parts FLUX",
                "value": "local_parts_flux_16gb",
                "description": "Download FLUX Kontext INT4 r32 for part extraction. Brain handles the vision planner."
              },
              {
                "label": "Local Image Stack",
                "value": "local_image_stack_16gb",
                "description": "Download Z-Image, FLUX dev, and FLUX Kontext. Brain handles local vision models."
              },
              {
                "label": "FLUX.1-dev",
                "value": "flux_dev_int4_r32",
                "description": "Download local FLUX text-to-image model files"
              },
              {
                "label": "FLUX.1-Kontext",
                "value": "flux_kontext_int4_r32",
                "description": "Download local FLUX image editing and parts extraction model files"
              }
            ]
          },
          {
            "name": "license_ack",
            "type": "hidden",
            "label": "License/access acknowledged in popup",
            "arg": "--license-ack",
            "default": "yes",
            "optional": false
          },
          {
            "name": "hf_token",
            "type": "secret",
            "label": "Hugging Face token",
            "secret_id": "huggingface.token",
            "env": "NYMPHS3D_HF_TOKEN",
            "optional": true
          }
        ],
        "submit": {
          "label": "Fetch FLUX"
        }
      }
    ],
    "manager_actions": [
      {
        "id": "open_nymph_ui",
        "label": "Open UI",
        "entrypoint": "open_nymph_ui",
        "result": "open_in_manager"
      },
      {
        "id": "smoke_test",
        "label": "Smoke Test",
        "entrypoint": "smoke_test",
        "result": "show_output"
      },
      {
        "id": "open_weights",
        "label": "Open Weights",
        "entrypoint": "open_weights",
        "result": "open_directory"
      },
      {
        "id": "open_outputs",
        "label": "Open",
        "entrypoint": "open_outputs",
        "result": "open_directory"
      },
      {
        "id": "open_config",
        "label": "Open Presets",
        "entrypoint": "open_image_presets",
        "result": "open_directory"
      },
      {
        "id": "open_lora",
        "label": "Open LoRA",
        "entrypoint": "open_lora",
        "result": "open_directory"
      },
      {
        "id": "start",
        "label": "Start",
        "entrypoint": "start",
        "result": "show_output"
      },
      {
        "id": "restart",
        "label": "Restart",
        "entrypoint": "restart",
        "result": "show_output"
      },
      {
        "id": "stop",
        "label": "Stop",
        "entrypoint": "stop",
        "result": "show_output"
      },
      {
        "id": "logs",
        "label": "Logs",
        "entrypoint": "logs",
        "result": "open_notepad"
      }
    ]
  },
  "uninstall": {
    "supports_purge": true,
    "supports_data_delete": true,
    "requires_confirmation": true,
    "dry_run_arg": "--dry-run",
    "confirm_arg": "--yes",
    "purge_arg": "--purge",
    "data_only_arg": "--data-only",
    "preserve_by_default": [
      "outputs",
      "logs",
      "Hugging Face cache"
    ],
    "removes_by_default": [
      "runtime source files",
      ".venv-nunchaku",
      "generated module scripts"
    ]
  },
  "dependencies": {
    "python": "3.11",
    "cuda": "13.0 toolkit with nvcc",
    "torch": "2.11.0+cu130",
    "diffusers": "0.37.1",
    "nunchaku": {
      "repo": "https://github.com/nymphnerds/nunchaku.git",
      "commit": "a2a4f2444a092974ba53323ba0681a523ff98031"
    },
    "model": "Tongyi-MAI/Z-Image-Turbo",
    "nunchaku_weights": "nunchaku-ai/nunchaku-z-image-turbo",
    "supported_nunchaku_weights": [
      {
        "precision": "int4",
        "rank": 32,
        "file": "svdq-int4_r32-z-image-turbo.safetensors",
        "label": "INT4 r32 - fast / lower VRAM"
      },
      {
        "precision": "int4",
        "rank": 128,
        "file": "svdq-int4_r128-z-image-turbo.safetensors",
        "label": "INT4 r128 - balanced"
      },
      {
        "precision": "int4",
        "rank": 256,
        "file": "svdq-int4_r256-z-image-turbo.safetensors",
        "label": "INT4 r256 - highest rank"
      },
      {
        "precision": "fp4",
        "rank": 32,
        "file": "svdq-fp4_r32-z-image-turbo.safetensors",
        "label": "FP4 r32 - experimental compare"
      },
      {
        "precision": "fp4",
        "rank": 128,
        "file": "svdq-fp4_r128-z-image-turbo.safetensors",
        "label": "FP4 r128 - experimental compare"
      }
    ],
    "supported_precisions": [
      "auto",
      "int4",
      "fp4"
    ],
    "default_precision": "auto",
    "default_rank": 32
  },
  "notes": [
    "This module replaces the old Nymphs2D2 manager install target.",
    "The backend still accepts NYMPHS2D2 compatibility environment variables during migration.",
    "Do not vendor the Nunchaku clone or model weights into this repo."
  ]
}
