{
  "schema_version": 1,
  "module_id": "zimage",
  "title": "Z-Image Turbo Backend",
  "layout": "standard_module_detail",
  "regions": [
    {
      "id": "backend_readiness",
      "title": "BACKEND READINESS",
      "type": "status_grid",
      "description": "Shows whether the runtime, model cache, server, and smoke-test path are ready.",
      "items": [
        {
          "label": "Runtime",
          "status_key": "env_ready",
          "true_label": "Ready",
          "false_label": "Missing"
        },
        {
          "label": "Models",
          "status_key": "models_ready",
          "true_label": "Ready",
          "false_label": "Missing"
        },
        {
          "label": "Server",
          "status_key": "running",
          "true_label": "Running",
          "false_label": "Stopped"
        },
        {
          "label": "Health",
          "status_key": "health",
          "ok_values": [
            "ok"
          ]
        }
      ],
      "detail_key": "detail"
    },
    {
      "id": "model_weights",
      "title": "MODEL WEIGHTS",
      "type": "model_fetch",
      "description": "Fetches the base Z-Image Turbo model and the selected Nunchaku quantized weight.",
      "facts": [
        {
          "label": "GPU VRAM",
          "status_key": "gpu_vram_mb",
          "format": "{value} MB"
        },
        {
          "label": "Recommended",
          "status_key": "recommended_precision"
        },
        {
          "label": "Weight repo",
          "status_key": "nunchaku_weight_repo"
        }
      ],
      "controls": [
        {
          "id": "precision",
          "label": "Precision",
          "type": "select",
          "default": "auto",
          "options": [
            {
              "value": "auto",
              "label": "Auto"
            },
            {
              "value": "int4",
              "label": "INT4"
            },
            {
              "value": "fp4",
              "label": "FP4"
            }
          ]
        },
        {
          "id": "rank",
          "label": "Rank",
          "type": "select",
          "default": "32",
          "options": [
            {
              "value": "32",
              "label": "r32"
            }
          ]
        }
      ],
      "actions": [
        {
          "label": "Fetch Model",
          "entrypoint": "fetch_models",
          "args": [
            "--precision",
            "${precision}",
            "--rank",
            "${rank}"
          ]
        },
        {
          "label": "Verify Cache",
          "entrypoint": "status"
        }
      ],
      "guide": [
        "Use Auto for most GPUs.",
        "On 12-16 GB VRAM, INT4 r32 is the safer first choice.",
        "FP4 can be tried when the GPU/runtime supports it and output quality is worth testing."
      ]
    },
    {
      "id": "endpoint",
      "title": "ENDPOINT",
      "type": "facts",
      "items": [
        {
          "label": "Server",
          "status_key": "url"
        },
        {
          "label": "Health",
          "status_key": "health_url"
        },
        {
          "label": "Info",
          "status_key": "server_info_url"
        },
        {
          "label": "Outputs",
          "status_key": "outputs_dir"
        },
        {
          "label": "Logs",
          "status_key": "logs_dir"
        },
        {
          "label": "HF cache",
          "status_key": "hf_cache_dir"
        }
      ]
    }
  ]
}
